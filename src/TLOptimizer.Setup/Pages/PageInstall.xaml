<UserControl x:Class="TLOptimizer.Setup.PageInstall"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel VerticalAlignment="Center">
    <TextBlock Text="Instalando TL Optimizer..." FontSize="18"
               FontWeight="Bold" Foreground="White" />
    <TextBlock x:Name="LblFile" Text="Preparando..."
               Foreground="{StaticResource TxtDimBrush}"
               FontSize="12" Margin="0,12,0,0"
               TextTrimming="CharacterEllipsis" />
    <ProgressBar x:Name="ProgressBar" Height="6" Margin="0,16,0,0"
                 Foreground="{StaticResource BlueBrush}"
                 Background="{StaticResource PanelBrush}"
                 BorderThickness="0" Minimum="0" Maximum="100" />
    <TextBlock x:Name="LblPercent" Text="0%"
               Foreground="{StaticResource TxtDimBrush}"
               FontSize="11" Margin="0,8,0,0" />
  </StackPanel>
</UserControl>
