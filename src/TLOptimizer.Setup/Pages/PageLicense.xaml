<UserControl x:Class="TLOptimizer.Setup.PageLicense"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Termos de uso e responsabilidade"
               FontSize="18" FontWeight="Bold" Foreground="White" />

    <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
            CornerRadius="8" Padding="16" Margin="0,12,0,12">
  <ScrollViewer>
    <ScrollViewer.Resources>
      <SolidColorBrush x:Key="ScrollTrackBrush" Color="#22222A" />
      <SolidColorBrush x:Key="ScrollThumbBrush" Color="#3C3C44" />
      <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#0067C0" />
      <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#0078D4" />

      <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource ScrollThumbBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="6" />
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource ScrollThumbHoverBrush}" />
          </Trigger>
          <Trigger Property="IsDragging" Value="True">
            <Setter Property="Background" Value="{StaticResource ScrollThumbPressedBrush}" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <ControlTemplate x:Key="VertScrollBar" TargetType="ScrollBar">
        <Grid Background="Transparent" Width="8">
          <Track Name="PART_Track" IsDirectionReversed="False">
            <Track.Thumb>
              <Thumb Style="{StaticResource ScrollThumbStyle}" />
            </Track.Thumb>
          </Track>
        </Grid>
      </ControlTemplate>

      <Style TargetType="ScrollBar">
        <Setter Property="Template" Value="{StaticResource VertScrollBar}" />
      </Style>
    </ScrollViewer.Resources>
    <TextBlock x:Name="TxtTerms" FontSize="12"
               Foreground="{StaticResource TxtDimBrush}"
               TextWrapping="Wrap" LineHeight="20" />
  </ScrollViewer>
    </Border>

    <CheckBox x:Name="ChkAccept" Grid.Row="2"
              Content="Eu li e aceito os termos de uso"
              Foreground="{StaticResource TxtDimBrush}"
              FontSize="12" Checked="OnAcceptChanged" Unchecked="OnAcceptChanged" />
  </Grid>
</UserControl>
